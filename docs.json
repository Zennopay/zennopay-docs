{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "Zennopay",
  "colors": {
    "primary": "#444CE7",
    "light": "#8891F5",
    "dark": "#3A41D8"
  },
  "favicon": "/images/favicon.svg",
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:site_name": "Zennopay Docs",
      "og:title": "Zennopay Docs — Cross-border QR payments, one SDK",
      "og:description": "Zennopay is a B2B SDK for cross-border QR payments in Southeast Asia. Your users scan any Thai PromptPay or Vietnamese VietQR code and pay from a USD wallet, inside your app, via one native PaymentSheet.",
      "og:image": "https://docs.zennopay.in/images/og-image.png",
      "og:type": "website",
      "twitter:card": "summary_large_image",
      "twitter:title": "Zennopay Docs — Cross-border QR payments, one SDK",
      "twitter:description": "Embed cross-border QR payments in your app. PromptPay & VietQR payouts from a USD wallet via one native PaymentSheet.",
      "twitter:image": "https://docs.zennopay.in/images/og-image.png"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "icon": "book-open",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "introduction",
              "quickstart",
              "how-zennopay-works"
            ]
          },
          {
            "group": "Make payments",
            "pages": [
              "payments/overview",
              "payments/session-endpoint",
              "payments/ios",
              "payments/android",
              "payments/flutter",
              "payments/react-native",
              "payments/testing",
              "payments/reopen-receipt"
            ]
          },
          {
            "group": "Fundamentals",
            "pages": [
              "authentication",
              "concepts/funds-flow",
              "concepts/corridors",
              "concepts/settlement",
              "fundamentals/limits"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "changelog"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "code",
        "groups": [
          {
            "group": "API Reference",
            "pages": [
              "api-reference/overview",
              "api-reference/environments",
              "api-reference/playground",
              {
                "group": "Payment Intents",
                "pages": [
                  "api-reference/payment-intents/create",
                  "api-reference/payment-intents/get",
                  "api-reference/payment-intents/receipt"
                ]
              },
              "api-reference/webhooks",
              "api-reference/jwt-inspector"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/sdks/overview",
      "destination": "/payments/overview"
    },
    {
      "source": "/sdks/session-endpoint",
      "destination": "/payments/session-endpoint"
    },
    {
      "source": "/sdks/ios",
      "destination": "/payments/ios"
    },
    {
      "source": "/sdks/android",
      "destination": "/payments/android"
    },
    {
      "source": "/sdks/flutter",
      "destination": "/payments/flutter"
    },
    {
      "source": "/sdks/react-native",
      "destination": "/payments/react-native"
    }
  ],
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "api": {
    "openapi": "openapi.json"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "background": {
    "decoration": "windows",
    "color": {
      "light": "#ffffff",
      "dark": "#091422"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Contact",
        "href": "mailto:support@zennopay.in"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Console",
      "href": "https://console.zennopay.in"
    }
  },
  "footer": {
    "socials": {
      "website": "https://zennopay.in"
    }
  },
  "fonts": {
    "heading": {
      "family": "Space Grotesk"
    },
    "body": {
      "family": "Inter"
    }
  }
}