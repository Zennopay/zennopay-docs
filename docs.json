{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "Zennopay",
  "colors": {
    "primary": "#6560FF",
    "light": "#c2c1ff",
    "dark": "#091422"
  },
  "favicon": "/images/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "icon": "book-open",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "introduction",
              "quickstart",
              "how-zennopay-works"
            ]
          },
          {
            "group": "Accept payments",
            "pages": [
              "payments/overview",
              "payments/session-endpoint",
              "payments/ios",
              "payments/android",
              "payments/flutter",
              "payments/react-native",
              "payments/testing"
            ]
          },
          {
            "group": "Fundamentals",
            "pages": [
              "authentication",
              "concepts/funds-flow",
              "concepts/corridors",
              "concepts/settlement",
              "fundamentals/limits"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "changelog"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "code",
        "groups": [
          {
            "group": "API Reference",
            "pages": [
              "api-reference/overview",
              "api-reference/environments",
              "api-reference/playground",
              {
                "group": "Payment Intents",
                "pages": [
                  "api-reference/payment-intents/create",
                  "api-reference/payment-intents/get"
                ]
              },
              "api-reference/webhooks",
              "api-reference/jwt-inspector"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/sdks/overview",
      "destination": "/payments/overview"
    },
    {
      "source": "/sdks/session-endpoint",
      "destination": "/payments/session-endpoint"
    },
    {
      "source": "/sdks/ios",
      "destination": "/payments/ios"
    },
    {
      "source": "/sdks/android",
      "destination": "/payments/android"
    },
    {
      "source": "/sdks/flutter",
      "destination": "/payments/flutter"
    },
    {
      "source": "/sdks/react-native",
      "destination": "/payments/react-native"
    }
  ],
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "api": {
    "openapi": "openapi.json"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "background": {
    "decoration": "windows",
    "color": {
      "light": "#ffffff",
      "dark": "#091422"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Contact",
        "href": "mailto:support@zennopay.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.zennopay.com"
    }
  },
  "footer": {
    "socials": {
      "website": "https://zennopay.com"
    }
  },
  "fonts": {
    "heading": {
      "family": "Space Grotesk"
    },
    "body": {
      "family": "Inter"
    }
  }
}